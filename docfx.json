{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "./FloatPanelLib",
          "files": ["**/*.csproj"]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": ["index.md", "toc.yml"]
      },
      {
        "files": ["**/*.{md,yml}"],
        "src": "docs",
        "dest": "docs"
      },
      {
        "files": ["**/*.{md,yml}"],
        "src": "demo",
        "dest": "demo"
      },
      {
        "files": ["**/*.yml"],
        "src": "api",
        "dest": "api"
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "output": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "FloatPanel",
      "_appTitle": "FloatPanel Documentation",
      "_enableSearch": true,
      "pdf": true,
      "_appFooter": "© 2026 FloatPanel.Avalonia",
      "_gitContribute": {
        "repo": "https://github.com/0use-TE/FloatPanel.Avalonia",
        "branch": "main"
      }
    }
  }
}
