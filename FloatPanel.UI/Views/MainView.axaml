<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:FloatPanel.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="1100"
             d:DesignHeight="900"
             x:Class="FloatPanel.UI.Views.MainView"
             x:DataType="vm:MainViewModel">

  <ScrollViewer>
    <StackPanel Margin="24" Spacing="24">

      <StackPanel Spacing="6">
        <TextBlock Text="FloatPanel Live Demo" FontSize="28" FontWeight="Bold" />
        <TextBlock Text="Default pattern: Spacer pushes content to both edges — the most common toolbar layout."
                   Opacity="0.75"
                   TextWrapping="Wrap" />
      </StackPanel>

      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="16"
              MaxWidth="1200">
        <StackPanel Spacing="12">
          <TextBlock Text="Playground" FontSize="18" FontWeight="SemiBold" />

          <FloatPanel Row="True" Spacing="2" Wrap="Wrap">
            <ToggleSwitch Content="Row" IsChecked="{Binding Row}" />
            <ToggleSwitch Content="Reverse" IsChecked="{Binding Reverse}" />
          </FloatPanel>

          <StackPanel Spacing="4">
            <TextBlock Text="{Binding Spacing, StringFormat=Spacing: {0} (×4 px)}" />
            <Slider Minimum="0" Maximum="16" Value="{Binding Spacing}" TickFrequency="1" IsSnapToTickEnabled="True" />
          </StackPanel>

          <FloatPanel Row="True" Spacing="2" Wrap="Wrap">
            <ComboBox ItemsSource="{Binding JustifyValues}" SelectedItem="{Binding Justify}" MinWidth="160" />
            <ComboBox ItemsSource="{Binding AlignItemsValues}" SelectedItem="{Binding AlignItems}" MinWidth="160" />
            <ComboBox ItemsSource="{Binding WrapValues}" SelectedItem="{Binding Wrap}" MinWidth="140" />
            <ComboBox ItemsSource="{Binding StretchItemsValues}" SelectedItem="{Binding StretchItems}" MinWidth="160" />
            <ComboBox ItemsSource="{Binding BreakpointValues}" SelectedItem="{Binding Breakpoint}" MinWidth="160" />
          </FloatPanel>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
              CornerRadius="8"
              Padding="16"
              MaxWidth="1200">
        <StackPanel Spacing="12">
          <TextBlock Text="Preview — Spacer toolbar" FontSize="18" FontWeight="SemiBold" />
          <TextBlock Text="One item on the left, two on the right; Spacer fills the middle."
                     Opacity="0.75"
                     TextWrapping="Wrap" />

          <Grid ColumnDefinitions="*,480">
            <Border Grid.Column="0"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12"
                    MinHeight="56">
              <FloatPanel Row="{Binding Row}"
                          Reverse="{Binding Reverse}"
                          Spacing="{Binding Spacing}"
                          Justify="{Binding Justify}"
                          AlignItems="{Binding AlignItems}"
                          Wrap="{Binding Wrap}"
                          StretchItems="{Binding StretchItems}"
                          Breakpoint="{Binding Breakpoint}">
                <Button Content="Settings" />
                <Spacer />
                <Button Content="Cancel" />
                <Button Content="Apply" Classes="accent" />
              </FloatPanel>
            </Border>

            <Border Grid.Column="1"
                    MinWidth="480"
                    Margin="12,0,0,0"
                    Background="#1E1E1E"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    IsVisible="{Binding IsPlaygroundCodeOpen}">
              <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="#2D2D2D" Padding="8,6">
                  <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Text="XAML" Foreground="#CCCCCC" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="flat" Padding="6,2" Foreground="#CCCCCC"
                            Content="Hide" Command="{Binding HidePlaygroundCodeCommand}" />
                  </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                              Padding="12"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                  <TextBlock Text="{Binding PlaygroundXaml}"
                             FontFamily="Consolas,Cascadia Mono,monospace"
                             FontSize="12"
                             Foreground="#D4D4D4"
                             TextWrapping="NoWrap" />
                </ScrollViewer>
              </Grid>
            </Border>

            <Button Grid.Column="1"
                    Width="36"
                    Margin="8,0,0,0"
                    Content="Code"
                    ToolTip.Tip="Show XAML"
                    Command="{Binding ShowPlaygroundCodeCommand}"
                    IsVisible="{Binding !IsPlaygroundCodeOpen}" />
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" MaxWidth="1200">
        <StackPanel Spacing="12">
          <TextBlock Text="Vertical stack" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,480">
            <Border Grid.Column="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12" MinHeight="180">
              <FloatPanel Spacing="2" Width="220">
                <TextBlock Text="Title" FontWeight="SemiBold" />
                <TextBlock Text="Description goes here." Opacity="0.7" TextWrapping="Wrap" />
                <Spacer />
                <Button Content="OK" HorizontalAlignment="Stretch" />
              </FloatPanel>
            </Border>
            <Border Grid.Column="1" MinWidth="480" Margin="12,0,0,0" Background="#1E1E1E" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
              <ScrollViewer Padding="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding VerticalExampleXaml}" FontFamily="Consolas,Cascadia Mono,monospace" FontSize="12" Foreground="#D4D4D4" TextWrapping="NoWrap" />
              </ScrollViewer>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" MaxWidth="1200">
        <StackPanel Spacing="12">
          <TextBlock Text="Wrap" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,480">
            <Border Grid.Column="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
              <FloatPanel Row="True" Wrap="Wrap" Spacing="2" MaxWidth="420">
                <Border Background="#EF5350" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 1" Foreground="White" /></Border>
                <Border Background="#AB47BC" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 2" Foreground="White" /></Border>
                <Border Background="#42A5F5" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 3" Foreground="White" /></Border>
                <Border Background="#66BB6A" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 4" Foreground="White" /></Border>
                <Border Background="#FFCA28" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 5" Foreground="White" /></Border>
                <Border Background="#8D6E63" CornerRadius="4" Padding="10,6"><TextBlock Text="Tag 6" Foreground="White" /></Border>
              </FloatPanel>
            </Border>
            <Border Grid.Column="1" MinWidth="480" Margin="12,0,0,0" Background="#1E1E1E" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
              <ScrollViewer Padding="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding WrapExampleXaml}" FontFamily="Consolas,Cascadia Mono,monospace" FontSize="12" Foreground="#D4D4D4" TextWrapping="NoWrap" />
              </ScrollViewer>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

      <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16" MaxWidth="1200">
        <StackPanel Spacing="12">
          <TextBlock Text="Responsive breakpoint" FontSize="18" FontWeight="SemiBold" />
          <Grid ColumnDefinitions="*,480">
            <Border Grid.Column="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
              <FloatPanel Row="True" Breakpoint="Md" Spacing="2">
                <Border Background="#5C6BC0" CornerRadius="4" Padding="12,8"><TextBlock Text="Left" Foreground="White" /></Border>
                <Border Background="#26A69A" CornerRadius="4" Padding="12,8"><TextBlock Text="Center" Foreground="White" /></Border>
                <Border Background="#FFA726" CornerRadius="4" Padding="12,8"><TextBlock Text="Right" Foreground="White" /></Border>
              </FloatPanel>
            </Border>
            <Border Grid.Column="1" MinWidth="480" Margin="12,0,0,0" Background="#1E1E1E" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
              <ScrollViewer Padding="12" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding BreakpointExampleXaml}" FontFamily="Consolas,Cascadia Mono,monospace" FontSize="12" Foreground="#D4D4D4" TextWrapping="NoWrap" />
              </ScrollViewer>
            </Border>
          </Grid>
        </StackPanel>
      </Border>

    </StackPanel>
  </ScrollViewer>
</UserControl>
